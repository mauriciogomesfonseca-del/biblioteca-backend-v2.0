# ============================================================
#  Ala dos Estudantes — Paiva Netto
#  Variáveis de ambiente — NUNCA commite o .env real no GitHub!
# ============================================================

# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=seu_jwt_secret_muito_longo_aqui

# Senhas com bcrypt hash
# Para gerar: npm run gerar-hash -- suasenha
SENHA_RECEPCAO_HASH=$2a$10$HASH_DA_SENHA_RECEPCAO_AQUI
SENHA_ADMIN_HASH=$2a$10$HASH_DA_SENHA_ADMIN_AQUI

# Cron secret — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=seu_cron_secret_aqui

# Gateway de pagamento (Passo 3 — deixe vazio por enquanto)
MERCADOPAGO_ACCESS_TOKEN=
EFIBANK_CLIENT_ID=
EFIBANK_CLIENT_SECRET=

# Control iD (Passo 4 — deixe vazio por enquanto)
CONTROLID_URL=
CONTROLID_TOKEN=
