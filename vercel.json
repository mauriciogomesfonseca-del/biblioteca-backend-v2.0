{
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/agente/(.*)",
      "dest": "/api/index"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index"
    },
    {
      "src": "/totem",
      "dest": "/totem.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/acessos?acao=reset-diario&token=edb8d8926d28bb2d540456fdc558e4df08d4447cda57750f2b4355774890dccf",
      "schedule": "45 22 * * *"
    }
  ]
}
