{
  "version": 2,
  "functions": {
    "api/*.js": { "memory": 256, "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth" },
    { "source": "/api/acessos/:path*", "destination": "/api/acessos" },
    { "source": "/api/usuarios/:path*", "destination": "/api/usuarios" },
    { "source": "/api/vagas/:path*", "destination": "/api/vagas" },
    { "source": "/api/configuracoes/:path*", "destination": "/api/configuracoes" },
    { "source": "/api/pagamentos/:path*", "destination": "/api/pagamentos" },
    { "source": "/api/avisos/:path*", "destination": "/api/avisos" },
    { "source": "/api/sugestoes/:path*", "destination": "/api/sugestoes" },
    { "source": "/api/totem/:path*", "destination": "/api/totem" },
    { "source": "/api/ping", "destination": "/api/ping" }
  ],
  "crons": [
    {
      "path": "/api/acessos?acao=encerrar-dia",
      "schedule": "45 22 * * *"
    }
  ]
}
