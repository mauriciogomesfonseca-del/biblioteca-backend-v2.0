{
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/agente/(.*)",
      "dest": "/api/index"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index"
    },
    {
      "src": "/totem",
      "dest": "/totem.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/acessos?acao=reset-diario&token=COLE_SEU_CRON_TOKEN_AQUI",
      "schedule": "45 22 * * *"
    }
  ]
}

