# ═══════════════════════════════════════════════════════════
#  .env.example — TEMPLATE DE VARIÁVEIS DE AMBIENTE
#  Copie para .env.local e preencha com os valores reais.
#  NUNCA commite .env.local ou .env.production no Git.
# ═══════════════════════════════════════════════════════════

# ── SUPABASE ─────────────────────────────────────────────────
# Painel Supabase → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT ──────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Mínimo 32 caracteres aleatórios — nunca reutilizar entre projetos
JWT_SECRET=gere_um_valor_aleatorio_de_48_bytes_aqui

# ── SENHAS DA RECEPÇÃO E ADMIN (bcrypt hash) ─────────────────
# Gerar com: node -e "const b=require('bcryptjs');b.hash('SUA_SENHA',12).then(console.log)"
# A senha em texto não fica em lugar nenhum — só o hash
SENHA_RECEPCAO_HASH=$2b$12$HASH_DA_SENHA_RECEPCAO_AQUI
SENHA_ADMIN_HASH=$2b$12$HASH_DA_SENHA_ADMIN_AQUI

# ── CRON TOKEN ───────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Usado pelo Vercel Cron para autenticar o reset diário de vagas
# O vercel.json chama /api/acessos?acao=reset-diario — sem token na URL
# Configure este valor no painel Vercel → Environment Variables
CRON_TOKEN=gere_um_valor_aleatorio_de_32_bytes_aqui

# ── GATEWAY DE PAGAMENTO (opcional até ter contrato) ─────────
# Preencher no painel Admin do sistema após contrato com gateway
# gateway_tipo: efi | mercadopago | pagarme | manual
# Estes valores ficam no banco (tabela configuracoes), não aqui
# Documentado aqui apenas para referência:
# GATEWAY_TIPO=efi
# GATEWAY_CHAVE=client_id:client_secret
# GATEWAY_CHAVE_PIX=chave_pix_cnpj_ou_email
